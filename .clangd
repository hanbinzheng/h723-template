CompileFlags:
  CompilationDatabase: "build/Debug"
  Add: [
    "-target", "arm-none-eabi",
    "-Wno-unknown-attributes",
    "-Wno-missing-braces",
    "-isystem", "/opt/arm-gnu-toolchain-15.2.rel1-darwin-arm64-arm-none-eabi/arm-none-eabi/include",
    "-isystem", "/opt/arm-gnu-toolchain-15.2.rel1-darwin-arm64-arm-none-eabi/lib/gcc/arm-none-eabi/15.2.1/include",
    "--sysroot=/opt/arm-gnu-toolchain-15.2.rel1-darwin-arm64-arm-none-eabi/arm-none-eabi"
  ]

Diagnostics:
  Suppress: [
    "pp_file_not_used",
    "unused-includes"
  ]
